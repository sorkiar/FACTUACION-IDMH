            <textField pattern="###,##0.00">
                <reportElement x="473" y="18" width="82" height="14"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[$V{descuento}]]></textFieldExpression>
            </textField>

            <!-- OP. GRAVADAS -->
            <staticText>
                <reportElement x="330" y="32" width="120" height="14" forecolor="#093697"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[OP. GRAVADAS :]]></text>
            </staticText>
            <textField>
                <reportElement x="453" y="32" width="20" height="14"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{comp_simbolo_moneda}]]></textFieldExpression>
            </textField>
            <textField pattern="###,##0.00">
                <reportElement x="473" y="32" width="82" height="14"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[($V{subtotal}.doubleValue() - $V{descuento}) * 0.82]]></textFieldExpression>
            </textField>

            <!-- I.G.V (18%) -->
            <staticText>
                <reportElement x="330" y="46" width="120" height="14" forecolor="#093697"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[I.G.V (18%) :]]></text>
            </staticText>
            <textField>
                <reportElement x="453" y="46" width="20" height="14"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{comp_simbolo_moneda}]]></textFieldExpression>
            </textField>
            <textField pattern="###,##0.00">
                <reportElement x="473" y="46" width="82" height="14"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[($V{subtotal}.doubleValue() - $V{descuento}) * 0.18]]></textFieldExpression>
            </textField>

            <!-- IMPORTE TOTAL -->
            <rectangle>
                <reportElement x="330" y="60" width="225" height="18" forecolor="#093697" backcolor="#093697"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="330" y="60" width="120" height="18" forecolor="#093697"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[IMPORTE TOTAL :]]></text>
            </staticText>
            <textField>
                <reportElement x="453" y="60" width="20" height="18"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Arial" size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{comp_simbolo_moneda}]]></textFieldExpression>
            </textField>
            <textField pattern="###,##0.00">
                <reportElement x="473" y="60" width="82" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$V{subtotal}.doubleValue() - $V{descuento}]]></textFieldExpression>
            </textField>

            <!-- Son (importe en letras) - columna izquierda -->
            <staticText>
                <reportElement x="0" y="4" width="50" height="14" forecolor="#093697"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Son :]]></text>
            </staticText>
            <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                <reportElement x="52" y="4" width="270" height="28"/>
                <box leftPadding="3" topPadding="2" bottomPadding="2">
                    <pen lineWidth="0.5" lineColor="#2282C7"/>
                </box>
                <textElement verticalAlignment="Top"><font fontName="Arial" size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[InvoicingUtils.convertir(new java.math.BigDecimal($V{subtotal}.doubleValue() - $V{descuento}))]]></textFieldExpression>
            </textField>

            <!-- Condición de pago -->
            <staticText>
                <reportElement x="0" y="70" width="80" height="14" forecolor="#093697"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Condición :]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="82" y="70" width="200" height="14"/>
                <box leftPadding="3"/>
                <textElement verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{comp_condicion_pago}]]></textFieldExpression>
            </textField>

            <!-- Línea separadora -->
            <line>
                <reportElement x="0" y="90" width="555" height="1" forecolor="#999999"/>
                <graphicElement><pen lineWidth="0.5" lineStyle="Dashed"/></graphicElement>
            </line>

            <!-- Nota de validez -->
            <rectangle>
                <reportElement x="0" y="96" width="555" height="30" forecolor="#FFF8E1" backcolor="#FFF8E1"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#FFC107"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="96" width="555" height="30" forecolor="#5D4037"/>
                <box leftPadding="8" rightPadding="8" topPadding="4"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true" isItalic="true"/>
                </textElement>
                <text><![CDATA[DOCUMENTO DE COTIZACIÓN — No tiene validez fiscal ni legal como comprobante de pago.
Los precios y condiciones son referenciales y están sujetos a cambio sin previo aviso.]]></text>
            </staticText>

            <!-- Vigencia -->
            <staticText>
                <reportElement x="0" y="132" width="555" height="14" forecolor="#666666"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isItalic="true"/>
                </textElement>
                <text><![CDATA[Vigencia de la cotización: 15 días hábiles a partir de la fecha de emisión.]]></text>
            </staticText>

        </band>
    </summary>

</jasperReport>
