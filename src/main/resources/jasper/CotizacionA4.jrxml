    <field name="itco_tipo_igv" class="java.lang.Integer"/>
    <field name="itco_igv" class="java.math.BigDecimal"/>

    <variable name="subtotal" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[new java.math.BigDecimal($F{itco_cantidad}*$F{itco_precio_unitario}).setScale(2, java.math.RoundingMode.HALF_UP)]]></variableExpression>
    </variable>
    <variable name="descuento" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{itco_descuento}.doubleValue()]]></variableExpression>
    </variable>
    <variable name="totaligv" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[($F{itco_cantidad}*$F{itco_precio_unitario})*0.18]]></variableExpression>
    </variable>
    <variable name="afecto" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[($F{itco_cantidad}*$F{itco_precio_unitario}) - (($F{itco_cantidad}*$F{itco_precio_unitario})*0.18)]]></variableExpression>
    </variable>
    <variable name="otros" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{otros_tributos}]]></variableExpression>
    </variable>
    <variable name="ticbper" class="java.lang.Double" calculation="Sum">
        <variableExpression><![CDATA[$F{icbper}]]></variableExpression>
    </variable>
    <variable name="valor_venta" class="java.lang.Double">
        <variableExpression><![CDATA[$V{subtotal}.doubleValue() - $V{descuento}]]></variableExpression>
    </variable>

