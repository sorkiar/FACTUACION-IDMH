<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="ReporteVentasA4" language="groovy" pageWidth="842" pageHeight="595"
              orientation="Landscape" whenNoDataType="AllSectionsNoDetail"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="15" bottomMargin="15"
              uuid="rep0rte-vent-as00-0000-000000000001">
    <import value="com.service.api.idmhperu.util.InvoicingUtils"/>
    <style name="Default" isDefault="true" mode="Transparent" hTextAlign="Left"
           vTextAlign="Middle" isBlankWhenNull="true" fontName="Arial" fontSize="7"
           pdfFontName="Helvetica"/>
    <style name="Cabecera" mode="Opaque" backcolor="#093697" forecolor="#FFFFFF"
           hTextAlign="Center" vTextAlign="Middle" fontName="Arial" fontSize="8" isBold="true"
           pdfFontName="Helvetica-Bold">
        <box>
            <pen lineWidth="0.5" lineColor="#FFFFFF"/>
        </box>
    </style>
    <style name="FilaImpar" mode="Transparent" hTextAlign="Left" vTextAlign="Middle"
           isBlankWhenNull="true" fontName="Arial" fontSize="7" pdfFontName="Helvetica">
        <conditionalStyle>
            <conditionExpression><![CDATA[$V{REPORT_COUNT}%2 == 0]]></conditionExpression>
            <style mode="Opaque" backcolor="#EDF4FF"/>
        </conditionalStyle>
    </style>
    <style name="TotalBar" mode="Opaque" backcolor="#093697" forecolor="#FFFFFF"
           hTextAlign="Right" vTextAlign="Middle" fontName="Arial" fontSize="8" isBold="true"
           pdfFontName="Helvetica-Bold">
        <box leftPadding="3" rightPadding="3"/>
    </style>

    <parameter name="urlImagen" class="java.lang.String"/>
    <parameter name="rango_fechas" class="java.lang.String"/>
    <parameter name="filtro_info" class="java.lang.String"/>
    <parameter name="total_registros" class="java.lang.Integer"/>

    <field name="empr_razon_social" class="java.lang.String"/>
    <field name="num" class="java.lang.Integer"/>
    <field name="fecha" class="java.lang.String"/>
    <field name="cliente_nombre" class="java.lang.String"/>
    <field name="cliente_doc" class="java.lang.String"/>
    <field name="num_comprobante" class="java.lang.String"/>
    <field name="estado_doc" class="java.lang.String"/>
    <field name="descripcion_items" class="java.lang.String"/>
    <field name="subtotal" class="java.math.BigDecimal"/>
    <field name="igv" class="java.math.BigDecimal"/>
    <field name="total" class="java.math.BigDecimal"/>

    <variable name="sum_subtotal" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{subtotal}]]></variableExpression>
        <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
    </variable>
    <variable name="sum_igv" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{igv}]]></variableExpression>
        <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
    </variable>
    <variable name="sum_total" class="java.math.BigDecimal" calculation="Sum">
        <variableExpression><![CDATA[$F{total}]]></variableExpression>
        <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
    </variable>
    <variable name="count_ventas" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$F{num}]]></variableExpression>
    </variable>

    <pageHeader>
        <band height="80" splitType="Stretch">

            <image scaleImage="RetainShape" hAlign="Left" vAlign="Middle">
                <reportElement x="0" y="0" width="120" height="45" uuid="logo"/>
                <imageExpression><![CDATA[$P{urlImagen}]]></imageExpression>
            </image>

            <textField isBlankWhenNull="true">
                <reportElement x="125" y="0" width="540" height="16" uuid="razon"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{empr_razon_social}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="125" y="16" width="540" height="18" forecolor="#093697" uuid="titulo"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="13" isBold="true"/>
                </textElement>
                <text><![CDATA[REPORTE DE VENTAS]]></text>
            </staticText>

            <staticText>
                <reportElement x="0" y="50" width="65" height="12" forecolor="#093697" uuid="lbl-rango"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Periodo :]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="68" y="50" width="200" height="12" uuid="val-rango"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="Arial" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{rango_fechas}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="63" width="65" height="12" forecolor="#093697" uuid="lbl-filtro"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Filtros :]]></text>
            </staticText>
            <textField isBlankWhenNull="true">
                <reportElement x="68" y="63" width="500" height="12" uuid="val-filtro"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="Arial" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{filtro_info}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="78" width="802" height="1" forecolor="#093697" uuid="line-header"/>
                <graphicElement>
                    <pen lineWidth="1.0"/>
                </graphicElement>
            </line>

        </band>
    </pageHeader>

    <columnHeader>
        <band height="16" splitType="Stretch">
            <staticText>
                <reportElement style="Cabecera" x="0" y="0" width="22" height="16" uuid="ch-num"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[#]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="22" y="0" width="58" height="16" uuid="ch-fecha"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="80" y="0" width="125" height="16" uuid="ch-cliente"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Cliente]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="205" y="0" width="70" height="16" uuid="ch-docid"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[N Doc. Identidad]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="275" y="0" width="95" height="16" uuid="ch-comp"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Comprobante]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="370" y="0" width="55" height="16" uuid="ch-estado"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Estado]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="425" y="0" width="197" height="16" uuid="ch-art"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Articulos]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="622" y="0" width="60" height="16" uuid="ch-sub"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Subtotal]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="682" y="0" width="55" height="16" uuid="ch-igv"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[IGV]]></text>
            </staticText>
            <staticText>
                <reportElement style="Cabecera" x="737" y="0" width="65" height="16" uuid="ch-tot"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Total (S/)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="14" splitType="Stretch">
            <rectangle>
                <reportElement style="FilaImpar" stretchType="RelativeToBandHeight"
                               x="0" y="0" width="802" height="14" uuid="det-bg"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <textField isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="0" y="1" width="22" height="12" uuid="det-num"/>
                <box leftPadding="2" rightPadding="2"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{num}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="22" y="1" width="58" height="12" uuid="det-fecha"/>
                <box leftPadding="2"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{fecha}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="80" y="1" width="125" height="12" uuid="det-cli"/>
                <box leftPadding="2"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="Arial" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{cliente_nombre}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="205" y="1" width="70" height="12" uuid="det-docid"/>
                <box leftPadding="2"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{cliente_doc}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="275" y="1" width="95" height="12" uuid="det-comp"/>
                <box leftPadding="2"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{num_comprobante}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="370" y="1" width="55" height="12" uuid="det-estado"/>
                <box leftPadding="2"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{estado_doc}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="425" y="1" width="197" height="12" uuid="det-art"/>
                <box leftPadding="2"/>
                <textElement verticalAlignment="Middle">
                    <font fontName="Arial" size="6"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{descripcion_items}]]></textFieldExpression>
            </textField>
            <textField pattern="###,##0.00" isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="622" y="1" width="60" height="12" uuid="det-sub"/>
                <box rightPadding="3"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{subtotal}]]></textFieldExpression>
            </textField>
            <textField pattern="###,##0.00" isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="682" y="1" width="55" height="12" uuid="det-igv"/>
                <box rightPadding="3"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="7"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{igv}]]></textFieldExpression>
            </textField>
            <textField pattern="###,##0.00" isBlankWhenNull="true">
                <reportElement style="FilaImpar" x="737" y="1" width="65" height="12" uuid="det-tot"/>
                <box rightPadding="3"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>

            <line>
                <reportElement x="0" y="13" width="802" height="1" forecolor="#CCCCCC" uuid="det-line"/>
                <graphicElement>
                    <pen lineWidth="0.25"/>
                </graphicElement>
            </line>
        </band>
    </detail>

    <summary>
        <band height="58" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="802" height="1" forecolor="#093697" uuid="sum-line"/>
                <graphicElement>
                    <pen lineWidth="1.0"/>
                </graphicElement>
            </line>

            <!-- Fila 1: count de ventas -->
            <staticText>
                <reportElement style="TotalBar" x="425" y="3" width="197" height="16" uuid="lbl-count"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[  Total de ventas:]]></text>
            </staticText>
            <textField>
                <reportElement style="TotalBar" x="622" y="3" width="180" height="16" uuid="val-count"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{count_ventas} + " venta(s)"]]></textFieldExpression>
            </textField>

            <!-- Fila 2: subtotal | igv | total -->
            <staticText>
                <reportElement style="TotalBar" x="425" y="20" width="197" height="16" uuid="lbl-totales"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[  Totales:]]></text>
            </staticText>
            <textField pattern="S/ ###,##0.00">
                <reportElement style="TotalBar" x="622" y="20" width="60" height="16" uuid="val-sum-sub"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{sum_subtotal} != null ? $V{sum_subtotal} : java.math.BigDecimal.ZERO]]></textFieldExpression>
            </textField>
            <textField pattern="S/ ###,##0.00">
                <reportElement style="TotalBar" x="682" y="20" width="55" height="16" uuid="val-sum-igv"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{sum_igv} != null ? $V{sum_igv} : java.math.BigDecimal.ZERO]]></textFieldExpression>
            </textField>
            <textField pattern="S/ ###,##0.00">
                <reportElement style="TotalBar" x="737" y="20" width="65" height="16" uuid="val-sum-tot"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{sum_total} != null ? $V{sum_total} : java.math.BigDecimal.ZERO]]></textFieldExpression>
            </textField>

            <!-- Son (monto en letras) -->
            <staticText>
                <reportElement x="0" y="40" width="90" height="14" forecolor="#093697" uuid="lbl-son"/>
                <box rightPadding="4"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Total son :]]></text>
            </staticText>
            <textField textAdjust="StretchHeight" isBlankWhenNull="true">
                <reportElement x="94" y="40" width="450" height="14" uuid="val-son"/>
                <box leftPadding="3" topPadding="2" bottomPadding="2">
                    <pen lineWidth="0.5" lineColor="#2282C7"/>
                </box>
                <textElement verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[InvoicingUtils.convertir($V{sum_total} != null ? $V{sum_total} : java.math.BigDecimal.ZERO)]]></textFieldExpression>
            </textField>

        </band>
    </summary>

</jasperReport>
