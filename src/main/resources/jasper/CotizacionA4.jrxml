                <box bottomPadding="1"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{itco_cantidad} * $F{itco_precio_unitario}]]></textFieldExpression>
            </textField>
