                <box bottomPadding="1"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Arial" size="7"/></textElement>
                <textFieldExpression><![CDATA[($F{itco_descuento} == null || $F{itco_descuento}.compareTo(java.math.BigDecimal.ZERO) == 0) ? "0%" : (Math.round($F{itco_descuento}.doubleValue() / ($F{itco_cantidad}.doubleValue() * $F{itco_precio_unitario}.doubleValue()) * 100) + "%")]]></textFieldExpression>
            </textField>
            <textField pattern="###0.00" isBlankWhenNull="true">
                <reportElement style="ColorIntercalado" x="405" y="1" width="58" height="12"/>
                <box bottomPadding="1"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="7"/></textElement>
